PROXY_TARGET_URL=https://your-relay-station.com
PROXY_API_KEY=sk-xxx
PROXY_PORT=3029
API_TIMEOUT=300
ACCESS_API_KEY=your-access-key

# Thinking 配置
# ENABLE_THINKING=true  → 对所有请求强制开启 thinking（适合 opus 模型）
# ENABLE_THINKING=false → 仅当模型名含 -thinking 后缀时才启用（默认）
ENABLE_THINKING=false

# THINKING_BUDGET 推理强度（ENABLE_THINKING=true 时生效）
# low    = 1024  tokens（快速，适合简单任务）
# medium = 8000  tokens（均衡，Claude Code 官方推荐）
# high   = 16000 tokens（深度推理，适合复杂任务）
THINKING_BUDGET=medium
